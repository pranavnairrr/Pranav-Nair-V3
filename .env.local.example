# ── Option A: LinkedIn API (requires approved r_member_social scope) ────────
# Access token expires every 60 days — regenerate at linkedin.com/developers
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# Your numeric LinkedIn member ID
# Find it: GET https://api.linkedin.com/v2/me  (with your token)
LINKEDIN_MEMBER_ID=your_member_id_here

# ── Option B: RSS.app feed (free, no API approval needed) ───────────────────
# 1. Go to https://rss.app  → Create feed → paste: https://linkedin.com/in/pranavnairrr
# 2. Copy the feed URL (looks like https://rss.app/feeds/xxxxxxxxxx.xml)
# 3. Paste it below — no other credentials needed
LINKEDIN_RSS_URL=https://rss.app/feeds/xxxxxxxxxx.xml

# The API route tries Option A first, then falls back to Option B automatically.
# You only need to fill in ONE of the two options above.
